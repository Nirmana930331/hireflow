# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────

# Secret key for signing JWT tokens — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-secret-in-production

# ── Database ──────────────────────────────────────────────────────────────────

# SQLite (default — good for development and small teams)
DATABASE_URL=sqlite:///hireflow.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/hireflow

# ── Server ────────────────────────────────────────────────────────────────────

PORT=5000
FLASK_DEBUG=true

# Allowed CORS origins (comma-separated in production, * for dev)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── File uploads ──────────────────────────────────────────────────────────────

UPLOAD_FOLDER=uploads

# ── Frontend (set in frontend/.env) ───────────────────────────────────────────
# VITE_API_URL=http://localhost:5000/api
